<Window x:Class="LyraFlow.UI.StatusOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LyraFlow Overlay" SizeToContent="WidthAndHeight" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize" 
        WindowStartupLocation="Manual"
        Icon="/Icon/app_icon.ico">
    <Window.Resources>
        <Storyboard x:Key="WaveAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Bar1" Storyboard.TargetProperty="Height" From="4" To="12" Duration="0:0:0.25" />
            <DoubleAnimation Storyboard.TargetName="Bar2" Storyboard.TargetProperty="Height" From="3" To="9" Duration="0:0:0.20" BeginTime="0:0:0.05" />
            <DoubleAnimation Storyboard.TargetName="Bar3" Storyboard.TargetProperty="Height" From="2" To="11" Duration="0:0:0.30" BeginTime="0:0:0.1" />
            <DoubleAnimation Storyboard.TargetName="Bar4" Storyboard.TargetProperty="Height" From="3" To="9" Duration="0:0:0.22" BeginTime="0:0:0.07" />
            <DoubleAnimation Storyboard.TargetName="Bar5" Storyboard.TargetProperty="Height" From="4" To="12" Duration="0:0:0.28" BeginTime="0:0:0.03" />
        </Storyboard>
        <Storyboard x:Key="ProcessingAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="RecordingBars" Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.8" />
        </Storyboard>
    </Window.Resources>
    
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Minimal Indicator (Recording/Processing) -->
        <Border x:Name="IndicatorGroup" Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Center">
            <Grid Height="12" Width="30">
                <Rectangle x:Name="IdleBar" Fill="#2dd4bf" Width="24" Height="4" RadiusX="2" RadiusY="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel x:Name="RecordingBars" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Height="12" Visibility="Hidden">
                    <Rectangle x:Name="Bar1" Fill="#14b8a6" Width="4" Height="4" Margin="0,0,1,0" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="Bar2" Fill="#14b8a6" Width="4" Height="4" Margin="0,0,1,0" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="Bar3" Fill="#14b8a6" Width="4" Height="4" Margin="0,0,1,0" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="Bar4" Fill="#14b8a6" Width="4" Height="4" Margin="0,0,1,0" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                    <Rectangle x:Name="Bar5" Fill="#14b8a6" Width="4" Height="4" Margin="0,0,0,0" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Review Panel (Preview text) -->
        <Border x:Name="ReviewPanel" Grid.Row="1" Background="#1e293b" CornerRadius="8" Padding="10" Margin="0,5,0,0" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                    <TextBlock x:Name="PreviewText" Foreground="White" TextWrapping="Wrap" FontSize="14" FontFamily="Segoe UI Variable Text"/>
                </ScrollViewer>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <TextBlock Text="[ENTER] Aceptar" Foreground="#2dd4bf" FontSize="11" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock Text="[ESC] Descartar" Foreground="#f43f5e" FontSize="11" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
