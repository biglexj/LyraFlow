<Window x:Class="LyraFlow.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajustes - LyraFlow" Width="410" SizeToContent="Height" MinHeight="580"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Icon="/Icon/app_icon.ico">
    <Window.Resources>
        <!-- Turquoise Button Style (Guardar) -->
        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#14b8a6"/>
            <Setter Property="Foreground" Value="#ecfdf5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#0d9488"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0d9488"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Hotkey Button Style -->
        <SolidColorBrush x:Key="CyanLightBg" Color="#232DD4BF" />
        <SolidColorBrush x:Key="CyanHoverBg" Color="#3D2DD4BF" />
        <Style x:Key="HotkeyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CyanLightBg}"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CyanHoverBg}"/>
                    <Setter Property="BorderBrush" Value="#14b8a6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Header Button Style -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CyanLightBg}"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#592DD4BF"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Global TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#16161d"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#14b8a6"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#14b8a6"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global PasswordBox Style -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#16161d"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#14b8a6"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#14b8a6"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global ComboBox Style -->
        <Style TargetType="ComboBox">
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
            <Setter Property="Background" Value="#16161d"/>
            <Setter Property="Foreground" Value="#f4f4f5"/>
            <Setter Property="BorderBrush" Value="#3f3f46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2" ClickMode="Press" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="templateBorder" Background="#16161d" BorderBrush="#3f3f46" BorderThickness="1" CornerRadius="8">
                                            <Grid HorizontalAlignment="Right" Width="24">
                                                <Path x:Name="Arrow" Fill="#f4f4f5" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="templateBorder" Property="BorderBrush" Value="#14b8a6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="8,3,28,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" Background="#1e1e26" BorderBrush="#3f3f46" BorderThickness="1" CornerRadius="8" Margin="0,2,0,0" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer Margin="0,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#14b8a6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#f4f4f5"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="itemBorder" Background="{TemplateBinding Background}" CornerRadius="6" Margin="4,1">
                                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#14b8a6"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#0d9488"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <!-- Main App Container -->
    <Border x:Name="MainBorder" Background="#16161d" CornerRadius="10" BorderBrush="#404040" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="12" Opacity="0.5" Direction="270" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/> <!-- Body -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border x:Name="HeaderBorder" Grid.Row="0" Background="Transparent" CornerRadius="10,10,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="12,10,14,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Image/Square44x44Logo.png" Width="20" Height="20" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock x:Name="HeaderTitle" Text="Ajustes - LyraFlow" FontSize="16" FontWeight="SemiBold" Foreground="#f4f4f5" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
                    </StackPanel>
                    <StackPanel x:Name="HeaderButtonsGroup" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Theme Toggle Button -->
                        <Button x:Name="ThemeToggleButton" Style="{StaticResource HeaderButtonStyle}" Content="🌙" Margin="0,0,6,0" ToolTip="Modo alterno" Click="ThemeToggle_Click"/>
                        <!-- Close Button -->
                        <Button x:Name="CloseWindowButton" Content="✕" ToolTip="Cerrar/Ocultar" Click="CloseWindowButton_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#38EF4444"/>
                                            <Setter Property="BorderBrush" Value="#73EF4444"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body Area (No Scroll) -->
            <StackPanel Grid.Row="1" Margin="16,4,16,12">
                <!-- General Section -->
                <TextBlock Text="GENERAL" FontSize="11" FontWeight="Bold" Foreground="#a1a1aa" Margin="0,6,0,8"/>
                <StackPanel Margin="23,0,0,10">
                    <CheckBox x:Name="AutoStartCheck" Content="Iniciar con Windows (minimizado)" Foreground="#a1a1aa" FontSize="12" VerticalContentAlignment="Center" Margin="0,0,0,12"/>
                    
                    <!-- Hotkey Section -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="GlobalHotkeyLabel" Text="Atajo global:" Foreground="#f4f4f5" FontSize="13" VerticalAlignment="Center" Grid.Column="0"/>
                        <Button x:Name="HotkeyPickerButton" Content="Control+Shift+Space" Style="{StaticResource HotkeyButtonStyle}" Width="160" Height="28" Margin="10,0,0,0" ToolTip="Haz clic para cambiar el atajo" FontSize="12" Grid.Column="1" Click="HotkeyPickerButton_Click" HorizontalAlignment="Left"/>
                    </Grid>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="#404040" Margin="0,6,0,12"/>

                <!-- Transcription Mode Section -->
                <TextBlock x:Name="TranscriptionModeLabel_Title" Text="MODO DE TRANSCRIPCIÓN" FontSize="11" FontWeight="Bold" Foreground="#a1a1aa" Margin="0,6,0,8"/>
                <StackPanel Margin="23,0,0,14">
                    <RadioButton x:Name="WhisperModeRadio" Content="Whisper" Foreground="#a1a1aa" FontSize="13" IsChecked="True" GroupName="TransMode" Checked="TranscriptionMode_Checked" Margin="0,0,0,8"/>
                    
                    <StackPanel x:Name="WhisperModelControls" Margin="20,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="WhisperModelCombo" Grid.Column="0" Height="28" FontSize="12" SelectionChanged="WhisperModelCombo_SelectionChanged" Margin="0,0,6,0">
                                <ComboBoxItem Content="Tiny"/>
                                <ComboBoxItem Content="Base"/>
                                <ComboBoxItem Content="Small"/>
                                <ComboBoxItem Content="Medium"/>
                                <ComboBoxItem Content="Large (Turbo)"/>
                            </ComboBox>
                            <Button x:Name="DownloadModelButton" Grid.Column="1" Content="DESCARGAR" FontSize="10" Padding="12,2" Style="{StaticResource HotkeyButtonStyle}" Height="28" Click="DownloadModelButton_Click" MinWidth="85"/>
                        </Grid>
                        <ProgressBar x:Name="DownloadProgress" Height="4" Margin="0,6,0,0" Foreground="#14b8a6" Background="#262626" BorderThickness="0" Visibility="Collapsed"/>
                        <TextBlock x:Name="ModelStatusText" Text="Modelo no descargado" Foreground="#EF4444" FontSize="10" Margin="0,2,0,0" Visibility="Collapsed"/>
                    </StackPanel>

                    <RadioButton x:Name="GroqRadio" Content="Groq Cloud" Foreground="#a1a1aa" FontSize="13" GroupName="TransMode" Checked="TranscriptionMode_Checked" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- API CONFIG SECTION -->
                <TextBlock Text="CONFIGURACIÓN API" FontSize="11" FontWeight="Bold" Foreground="#a1a1aa" Margin="0,0,0,8"/>
                <StackPanel Margin="23,0,0,12">
                    <TextBlock Text="Gemini API Key:" Foreground="#f4f4f5" FontSize="12" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="GeminiKeyBox" Height="28" Background="#16161d" Foreground="#f4f4f5" BorderBrush="#3f3f46" Padding="5,0"/>
                    
                    <PasswordBox x:Name="GroqKeyBox" Height="28" Background="#16161d" Foreground="#f4f4f5" BorderBrush="#3f3f46" Padding="5,0"/>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="#404040" Margin="0,12"/>

                <!-- Gemini AI Section -->
                <TextBlock x:Name="GeminiModelLabel_Title" Text="GEMINI AI" FontSize="11" FontWeight="Bold" Foreground="#a1a1aa" Margin="0,6,0,8"/>
                <!-- Gemini Model Selection -->
                <StackPanel Margin="23,0,0,10">
                    <TextBlock x:Name="GeminiModelLabel" Text="Seleccionar Modelo:" Foreground="#f4f4f5" FontSize="14" Margin="0,0,0,6"/>
                    <ComboBox x:Name="GeminiModelCombo" Height="32" FontSize="13" Cursor="Hand" SelectionChanged="GeminiModelCombo_SelectionChanged" Margin="0,0,0,6">
                        <ComboBoxItem Content="gemini-3-flash-preview"/>
                        <ComboBoxItem Content="gemini-3.1-flash-lite-preview"/>
                        <ComboBoxItem Content="gemini-2.5-flash"/>
                        <ComboBoxItem Content="gemini-2.5-flash-lite"/>
                    </ComboBox>
                    <CheckBox x:Name="SkipRefinementCheck" Content="Sin refinamiento (Inyectar transcripción directa)" Foreground="#a1a1aa" FontSize="12" VerticalContentAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

            </StackPanel>

            <Border Grid.Row="2" Margin="16,0,16,16">
                <Button Style="{StaticResource SaveButtonStyle}" Content="Guardar y ocultar" Click="HideWindow_Click"/>
            </Border>

            <!-- Custom Exit/Hide Dialog (Hidden by default) -->
            <Grid x:Name="ExitDialogPanel" Grid.RowSpan="3" Background="#cc16161d" Visibility="Collapsed" MouseLeftButtonDown="ExitDialogPanel_MouseLeftButtonDown">
                <Border Background="#1e1e26" CornerRadius="12" BorderBrush="#404040" BorderThickness="1" 
                        Width="280" Height="135" HorizontalAlignment="Center" VerticalAlignment="Center" MouseLeftButtonDown="ExitDialogBorder_MouseLeftButtonDown">
                    <StackPanel VerticalAlignment="Center" Margin="15,10">
                        <TextBlock Text="¿Qué deseas hacer?" Foreground="#f4f4f5" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="Elige una opción para LyraFlow." Foreground="#a1a1aa" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                        <UniformGrid Columns="2">
                            <Button Content="OCULTAR" Style="{StaticResource SaveButtonStyle}" Height="34" FontSize="11" Margin="0,0,4,0" Click="HideWindow_Click"/>
                            <Button Content="SALIR" Style="{StaticResource SaveButtonStyle}" Height="34" FontSize="11" Click="ExitApp_Confirm_Click"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
